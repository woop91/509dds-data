{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/Woop91/509dds-data/schemas/dataset.meta.schema.json",
  "title": "509dds-data dataset metadata (data card)",
  "description": "Sidecar metadata describing one dataset file for machine (AI) consumption. Lives next to the data file as <file>.meta.json.",
  "type": "object",
  "required": ["id", "title", "description", "path", "format", "source", "confidence_tier"],
  "additionalProperties": true,
  "properties": {
    "$schema": { "type": "string" },
    "id": { "type": "string", "description": "Stable dataset id: repo-relative path without extension, e.g. 'ssa/periodic-cdr-backlog-fy14-fy18'." },
    "title": { "type": "string" },
    "description": { "type": "string", "minLength": 1 },
    "path": { "type": "string", "description": "Repo-root-relative path to the data file this sidecar describes." },
    "format": { "type": "string", "enum": ["csv", "json", "xlsx", "md", "txt", "png", "pdf"] },
    "unit_of_observation": { "type": "string" },
    "row_count": { "type": ["integer", "null"] },
    "columns": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string", "enum": ["integer", "number", "string", "boolean", "date", "percent"] },
          "unit": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "temporal_coverage": {
      "type": "object",
      "properties": { "start": { "type": "string" }, "end": { "type": "string" } }
    },
    "geographic_coverage": { "type": "string" },
    "source": {
      "type": "object",
      "required": ["publisher", "url"],
      "properties": {
        "publisher": { "type": "string" },
        "title": { "type": "string" },
        "url": { "type": "string" },
        "retrieved_at": { "type": "string" }
      }
    },
    "confidence_tier": {
      "type": "string",
      "enum": ["Authoritative", "Computed", "Browser-fetch pending", "PRR-pending", "Structurally unavailable"]
    },
    "update_cadence": { "type": "string" },
    "license": { "type": "string" },
    "notes": { "type": "string" },
    "derived_from": { "type": "array", "items": { "type": "string" } },
    "related": { "type": "array", "items": { "type": "string" } },
    "tags": { "type": "array", "items": { "type": "string" } }
  }
}
