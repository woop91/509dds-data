  "crossCuttingConcepts": [
    {
      "id": "weingarten-rights",
      "name": "Weingarten Rights",
      "summary": "Right to union representation at any investigatory interview that could reasonably lead to discipline.",
      "appliesTo": "all bargaining-unit employees",
      "source": "NLRB v. J. Weingarten, Inc., 420 U.S. 251 (1975); applied to MA public sector via DLR precedent under c. 150E"
    },
    {
      "id": "loudermill-rights",
      "name": "Loudermill Due Process",
      "summary": "Notice and opportunity to respond before serious discipline for public employees with property interest in their job.",
      "appliesTo": "most civil-service positions and CBA-covered employees with just-cause clauses",
      "source": "Cleveland Bd. of Educ. v. Loudermill, 470 U.S. 532 (1985)"
    },
    {
      "id": "duty-of-fair-representation",
      "name": "Duty of Fair Representation",
      "summary": "Union must represent bargaining-unit members fairly — not arbitrarily, discriminatorily, or in bad faith.",
      "appliesTo": "every member of a bargaining unit",
      "source": "M.G.L. c. 150E; established case law"
    },
    {
      "id": "past-practice",
      "name": "Past Practice",
      "summary": "Established workplace practices can bind the employer even when not written in the CBA.",
      "appliesTo": "schedules, leave approvals, overtime distribution, remote work, office assignments, workload",
      "useFor": "proving CBA term meaning, blocking unilateral changes, supporting refusal-to-bargain ULPs"
    },
    {
      "id": "anti-retaliation",
      "name": "Cross-Statute Anti-Retaliation",
      "summary": "Almost every workplace law has its own anti-retaliation provision — adverse action after protected activity often becomes a separate, sometimes stronger claim.",
      "appliesTo": "any worker who engaged in protected activity (filing, complaining, requesting accommodation, taking leave, participating in union activity)",
      "criticalNote": "Deadlines vary by statute and some are very short (30 days for some). File or notify steward immediately on suspicion."
    }
  ]
