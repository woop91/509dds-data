{
  "name": "509dds-data",
  "version": "0.1.0",
  "private": true,
  "description": "509dds data pipeline + reference data; npm tooling exists solely to host the security pre-commit hook.",
  "scripts": {
    "ingest:markitdown": "python scripts/markitdown_bundle.py",
    "prepare": "husky",
    "security:scan:semgrep": "docker run --rm -v \"$PWD:/src\" semgrep/semgrep:1.91.0 semgrep --config=p/security-audit --config=p/javascript --config=p/python --config=/src/.semgrep.yml /src",
    "security:scan:gitleaks": "docker run --rm -v \"$PWD:/repo\" zricethezav/gitleaks:v8.21.2 detect --no-banner --source=/repo --config=/repo/.gitleaks.toml --baseline-path=/repo/.security/gitleaks-baseline.json"
  },
  "devDependencies": {
    "husky": "^9.1.7"
  }
}
