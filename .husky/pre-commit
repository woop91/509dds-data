#!/usr/bin/env sh
# Pre-commit gates for 509dds-data.
# Currently: gitleaks staged-only scan (via Docker for cross-platform install-free).
# Bypass for emergencies: git commit --no-verify (then file a rotation runbook entry)

set -e

echo "→ gitleaks (staged)"
docker run --rm -v "$(pwd):/repo" -w /repo zricethezav/gitleaks:v8.21.2 protect --staged --no-banner --config=/repo/.gitleaks.toml --baseline-path=/repo/.security/gitleaks-baseline.json

echo "✓ pre-commit checks passed"
